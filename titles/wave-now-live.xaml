<?xml version="1.0" encoding="utf-8"?>
<!--
  WAVE "Now Live" lower-third for vMix.

  Bind via the companion sidecar:
    SetText WaveStreamLabel    -> current encoder name
    SetText WaveBitrateKbps    -> current bitrate
    SetText WaveUptime         -> mm:ss
    SetColor WaveStatusDot     -> #16d6aa (green) / #f0c419 (yellow) / #ef4444 (red)
-->
<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Width="1920" Height="1080" Background="Transparent">
  <Border HorizontalAlignment="Left" VerticalAlignment="Bottom"
          Background="#cc0a0a0b" CornerRadius="6"
          Margin="48,0,0,72" Padding="20,12,28,12">
    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
      <Ellipse x:Name="WaveStatusDot" Width="14" Height="14" Fill="#16d6aa"
               VerticalAlignment="Center" Margin="0,0,12,0"/>
      <TextBlock Text="LIVE ON WAVE" Foreground="#f4f4f5"
                 FontFamily="Inter,Helvetica Neue,Arial" FontSize="22"
                 FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,16,0"/>
      <TextBlock x:Name="WaveStreamLabel" Text="—" Foreground="#a1a1aa"
                 FontFamily="Inter,Helvetica Neue,Arial" FontSize="18"
                 VerticalAlignment="Center" Margin="0,0,16,0"/>
      <TextBlock x:Name="WaveBitrateKbps" Text="0" Foreground="#a1a1aa"
                 FontFamily="Inter,Helvetica Neue,Arial" FontSize="16"
                 VerticalAlignment="Center" Margin="0,0,4,0"/>
      <TextBlock Text="kbps" Foreground="#71717a"
                 FontFamily="Inter,Helvetica Neue,Arial" FontSize="14"
                 VerticalAlignment="Center" Margin="0,0,16,0"/>
      <TextBlock x:Name="WaveUptime" Text="00:00" Foreground="#a1a1aa"
                 FontFamily="Inter,Helvetica Neue,Arial" FontSize="16"
                 VerticalAlignment="Center"/>
    </StackPanel>
  </Border>
</Grid>
